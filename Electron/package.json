{
  "name": "passsafer-electron",
  "version": "1.7.6",
  "description": "Secure Password Manager with Encryption",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "keywords": [
    "password",
    "manager",
    "security",
    "encryption"
  ],
  "author": "PassSafer",
  "license": "LICENCE",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "build": {
    "appId": "com.passsafer.app",
    "productName": "PassSafer",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "zyniotech",
      "repo": "passsafer",
      "releaseType": "release"
    },
    "files": [
      "**/*",
      "../logos/**/*",
      "!video_mock.js",
      "!video_index.html"
    ],
    "extraResources": [
      {
        "from": "../logos",
        "to": "logos",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../BrowserExtension/native-host.js",
        "to": "native-host/native-host.js"
      },
      {
        "from": "../BrowserExtension/native-host.bat",
        "to": "native-host/native-host.bat"
      },
      {
        "from": "../BrowserExtension/de.passsafer.helper.json",
        "to": "native-host/de.passsafer.helper.json"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "../logos/logo_win_linx.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "../logos/logo_win_linx.ico",
      "uninstallerIcon": "../logos/logo_win_linx.ico",
      "deleteAppDataOnUninstall": true,
      "include": "build/installer.nsh"
    },
    "mac": {
      "target": "dmg",
      "icon": "../logos/logo_mac.png"
    },
    "dmg": {
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    },
    "linux": {
      "target": "AppImage",
      "icon": "../logos/logo_win.png",
      "category": "Utility"
    }
  }
}
